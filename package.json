{
    "name": "sidebar-stock",
    "displayName": "Sidebar Stock",
    "description": "侧边栏标签页股票看盘工具，支持A股及板块、港股、美股，快速掌握自选股动态",
    "keywords": [
        "stock",
        "炒股",
        "股票",
        "股市",
        "A股",
        "港股",
        "美股",
        "自选股",
        "大盘"
    ],
    "version": "1.0.0",
    "publisher": "dimloong",
    "icon": "assets/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/DimLoong/sidebar-stock"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "configuration": {
            "title": "Sidebar Stock",
            "properties": {
                "sidebarStock.stockCodeList": {
                    "type": "array",
                    "default": [],
                    "items": {
                        "oneOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "object"
                            }
                        ]
                    },
                    "description": "推荐使用 JSON 数组配置。股票示例：{\"type\":\"stock\",\"market\":\"sh\",\"code\":\"600519\",\"shares\":100,\"costPrice\":1680,\"costDate\":\"2026-04-23\"}；板块示例：{\"type\":\"sector\",\"name\":\"航天\",\"code\":\"886078\"}；指数示例：{\"type\":\"index\",\"code\":\"DJI\"}；期货示例：{\"type\":\"future\",\"code\":\"IF0\",\"name\":\"沪深300股指主连\"}。兼容旧字符串格式并会自动迁移。"
                },
                "sidebarStock.tabName": {
                    "type": "string",
                    "default": "Stock",
                    "description": "Sidebar Stock 侧边栏标签页名称（仅影响视图标题）"
                },
                "sidebarStock.alerts.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "是否开启短时异动提醒"
                },
                "sidebarStock.alerts.windowMinutes": {
                    "type": "number",
                    "default": 3,
                    "minimum": 1,
                    "description": "异动检测滚动窗口（分钟）"
                },
                "sidebarStock.alerts.changePercent": {
                    "type": "number",
                    "default": 4,
                    "minimum": 0.5,
                    "description": "异动触发阈值（百分比）"
                },
                "sidebarStock.alerts.cooldownMinutes": {
                    "type": "number",
                    "default": 10,
                    "minimum": 1,
                    "description": "同一只股票异动提醒冷却时长（分钟）"
                },
                "sidebarStock.devMode": {
                    "type": "boolean",
                    "default": false,
                    "description": "开发者模式开关"
                },
                "sidebarStock.dev.alertTestStockEnabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "开发者模式：注入异动测试股票（虚拟数据）"
                },
                "stockInvestment.stockCodeList": {
                    "type": "array",
                    "default": [],
                    "deprecationMessage": "此配置项已弃用，请使用 sidebarStock.stockCodeList",
                    "items": {
                        "oneOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "object"
                            }
                        ]
                    },
                    "description": "旧版配置项，保留兼容。"
                },
                "stockInvestment.alerts.enabled": {
                    "type": "boolean",
                    "default": true,
                    "deprecationMessage": "此配置项已弃用，请使用 sidebarStock.alerts.enabled",
                    "description": "旧版配置项，保留兼容。"
                },
                "stockInvestment.alerts.windowMinutes": {
                    "type": "number",
                    "default": 3,
                    "minimum": 1,
                    "deprecationMessage": "此配置项已弃用，请使用 sidebarStock.alerts.windowMinutes",
                    "description": "旧版配置项，保留兼容。"
                },
                "stockInvestment.alerts.changePercent": {
                    "type": "number",
                    "default": 4,
                    "minimum": 0.5,
                    "deprecationMessage": "此配置项已弃用，请使用 sidebarStock.alerts.changePercent",
                    "description": "旧版配置项，保留兼容。"
                },
                "stockInvestment.alerts.cooldownMinutes": {
                    "type": "number",
                    "default": 10,
                    "minimum": 1,
                    "deprecationMessage": "此配置项已弃用，请使用 sidebarStock.alerts.cooldownMinutes",
                    "description": "旧版配置项，保留兼容。"
                }
            }
        },
        "views": {
            "explorer": [
                {
                    "id": "stockView",
                    "name": "Stock"
                }
            ]
        },
        "commands": [
            {
                "command": "extension.showStockPanel",
                "title": "Show Stock Panel"
            },
            {
                "command": "stockView.openWebsite",
                "icon": "$(link-external)",
                "title": "打开东方财富",
                "enablement": "view == stockView"
            },
            {
                "command": "stockView.refresh",
                "icon": "$(refresh)",
                "title": "刷新股票面板",
                "enablement": "view == stockView"
            },
            {
                "command": "stockView.editHoldingShares",
                "title": "编辑持仓信息",
                "enablement": "view == stockView && (viewItem == stockRoot || viewItem == stockHolding)"
            },
            {
                "command": "stockView.deleteStock",
                "title": "删除股票",
                "enablement": "view == stockView && (viewItem == stockRoot || viewItem == sectorRoot || viewItem == indexRoot || viewItem == futureRoot)"
            },
            {
                "command": "stockView.addStock",
                "icon": "$(add)",
                "title": "添加自选股",
                "enablement": "view == stockView"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "stockView.openWebsite",
                    "when": "view == stockView",
                    "group": "navigation@1"
                },
                {
                    "command": "stockView.refresh",
                    "when": "view == stockView",
                    "group": "navigation@2"
                },
                {
                    "command": "stockView.addStock",
                    "when": "view == stockView",
                    "group": "navigation@3"
                }
            ],
            "view/item/context": [
                {
                    "command": "stockView.editHoldingShares",
                    "when": "view == stockView && (viewItem == stockRoot || viewItem == stockHolding)",
                    "group": "stock@1"
                },
                {
                    "command": "stockView.deleteStock",
                    "when": "view == stockView && (viewItem == stockRoot || viewItem == sectorRoot || viewItem == indexRoot || viewItem == futureRoot)",
                    "group": "stock@2"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "webpack --mode production",
        "compile": "webpack",
        "watch": "webpack --watch",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.80.0",
        "@vscode/test-cli": "^0.0.11",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^9.39.2",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.52.0",
        "webpack": "^5.104.1",
        "webpack-cli": "^6.0.1"
    }
}
